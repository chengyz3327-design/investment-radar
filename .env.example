# 投资避雷 - 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ====== 必须配置 ======
# JWT 密钥 (生产环境必须修改)
JWT_SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars

# ====== 邮件配置 (可选) ======
# 用于邮箱验证、密码重置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_NAME=投资避雷

# ====== 支付配置 (可选) ======
# sandbox = 沙盒测试模式, production = 生产模式
PAYMENT_MODE=sandbox

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay/callback

# 微信支付配置
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat/callback

# ====== OAuth 第三方登录 (可选) ======
# 微信开放平台
WECHAT_OAUTH_APP_ID=
WECHAT_OAUTH_APP_SECRET=
WECHAT_OAUTH_REDIRECT_URI=https://your-domain.com/auth/callback/wechat

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-domain.com/auth/callback/github
